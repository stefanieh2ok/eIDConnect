# =====================================================================
# HookAI – Demo App – Environment Variables
# =====================================================================
# Hinweis: Lokal in .env.local kopieren. In Vercel als Production-/Preview-
# Variablen anlegen (Settings -> Environment Variables) und Redeploy.

# --------- OpenAI / Clara AI ---------
OPENAI_API_KEY=your_openai_api_key_here

# --------- Alternative AI Services (optional) ---------
# ALEPH_ALPHA_API_KEY=your_aleph_alpha_api_key_here
# STACKIT_API_KEY=your_stackit_api_key_here

# --------- App / Live URL ---------
NEXT_PUBLIC_APP_NAME=HookAI
NEXT_PUBLIC_APP_VERSION=1.0.0
# Live-URL der App, OHNE trailing Slash. Wird fuer Zugangslinks und Mails genutzt.
NEXT_PUBLIC_APP_URL=https://hookai-two.vercel.app
# Optional: andere Basis fuer die Zugangslinks (falls custom Domain).
# ACCESS_LINK_BASE_URL=https://demo.hookai.de

# --------- Supabase ---------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Optional: Supabase Personal Access Token (nur fuer /setup-Tooling).
# SUPABASE_ACCESS_TOKEN=sbp_xxx

# --------- Admin Basic Auth ---------
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASS=please_change_me_long_random
# Geheimer Parameter fuer /api/admin/enter-demo (Direktzugang ohne UI).
ADMIN_DEMO_SECRET=please_change_me_long_random

# --------- E-Mail-Versand (Resend) ---------
# Schritt-fuer-Schritt: docs/EMAIL-SETUP-RESEND.md
# 1) API-Key aus https://resend.com -> API Keys.
RESEND_API_KEY=re_xxx
# 2) Absenderadresse mit VERIFIZIERTER Domain. Solange diese auf
#    "onboarding@resend.dev" steht (Default), liefert Resend nur an
#    deine Resend-Account-Adresse - Tester bekommen nichts.
SEND_ACCESS_EMAIL_FROM=HookAI Demo <noreply@hookai.de>

# --------- DocuSign (NDA) ---------
# DOCUSIGN_USE_DEMO=true
# DOCUSIGN_INTEGRATION_KEY=...
# DOCUSIGN_USER_ID=...
# DOCUSIGN_ACCOUNT_ID=...
# DOCUSIGN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# --------- Development ---------
NODE_ENV=development
