# =====================================================================
# HookAI Civic Demo — Environment Variables (EXAMPLE ONLY — no secrets)
# =====================================================================
# Copy to .env.local and fill in real values. Never commit .env.local.

# --------- OpenAI / Clara ---------
OPENAI_API_KEY=your_openai_api_key_here
# CLARA_AI_PROVIDER=openai

# --------- App URL ---------
NEXT_PUBLIC_APP_NAME=HookAI
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3002

# --------- Supabase ---------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# SUPABASE_ACCESS_TOKEN=sbp_xxx

# --------- Admin Basic Auth ---------
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASS=please_change_me_long_random
ADMIN_DEMO_SECRET=please_change_me_long_random

# --------- E-Mail (Resend) ---------
RESEND_API_KEY=re_xxx
SEND_ACCESS_EMAIL_FROM=HookAI Demo <noreply@your-domain.example>
# ADMIN_NOTIFY_EMAIL=admin@example.com

# --------- DocuSign (optional) ---------
# DOCUSIGN_USE_DEMO=true
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# --------- Optional ---------
# ACCESS_LINK_BASE_URL=
# DEMO_ACCESS_DEFAULT_ID=
# DATABASE_URL=postgresql://...
# NEXT_PUBLIC_ENABLE_DEMO_LAUNCH_EFFECT=true

NODE_ENV=development
