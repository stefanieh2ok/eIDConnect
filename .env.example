# Supabase (für Demo-Beweislog und Admin)
NEXT_PUBLIC_SUPABASE_URL=https://vtauafbbzdvhrxoyfnpe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_7UcBom7p_5eu92WkP49mFw_37_py63s
# Project Settings → API → „Service role“ (secret) → Reveal → den LANGEN Key kopieren (nicht die Project-ID vtauaf...)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Tabelle access_requests per Klick anlegen (Setup-Seite „Tabelle jetzt anlegen“)
# Supabase Dashboard → Account (Profil) → Access Tokens → Generate new token
# SUPABASE_ACCESS_TOKEN=sbp_xxxx

# Admin Basic Auth (Middleware + APIs)
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASS=bitte-ein-langes-starkes-passwort

# E-Mail-Versand für Demo-Zugang (Resend)
RESEND_API_KEY=re_xxxx
# Optional: Stefanie Hook
# SEND_ACCESS_EMAIL_FROM=eIDConnect <stefanie.hook@hookai.eu>
# E-Mail-Adresse, die bei jeder neuen Zugangsanfrage (Startseite) benachrichtigt wird
# ADMIN_NOTIFY_EMAIL=deine-email@example.com

# Optional: Demo-ID für selbst angeforderten Zugang (Startseite „Zugang anfordern“)
# DEMO_ACCESS_DEFAULT_ID=eid-demo-connect-v1

# Tabelle access_requests (für „Zugang anfordern“): wird automatisch angelegt, wenn DATABASE_URL gesetzt ist.
# Supabase → Project Settings → Database → Connection string (URI) – [YOUR-PASSWORD] ersetzen.
# DATABASE_URL=postgresql://postgres.xxx:DEIN-PASSWORT@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# Optional: Einmal-URL zum manuellen Anlegen (ohne App-Neustart): SETUP_MIGRATE_SECRET=dein-secret setzen, dann /api/setup/migrate-access-requests?secret=dein-secret aufrufen.

# DocuSign (NDA mit rechtsverbindlicher Signatur)
# Integration Key aus DocuSign Admin → Apps and Keys
# DOCUSIGN_INTEGRATION_KEY=xxxx
# User ID (GUID) des Nutzers, unter dem die Envelopes gesendet werden
# DOCUSIGN_USER_ID=xxxx
# Account ID (GUID) des DocuSign-Accounts
# DOCUSIGN_ACCOUNT_ID=xxxx
# RSA Private Key (PEM) für JWT – aus DocuSign beim Erstellen des Keys; Zeilenumbrüche als \n oder echte Newlines
# DOCUSIGN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Optional: DocuSign Demo/Sandbox nutzen
# DOCUSIGN_USE_DEMO=true
# Optional: Anzeigename in der UI (Standard im Code: eIDConnect)
# NEXT_PUBLIC_APP_NAME=eIDConnect
# Optional: Basis-URL der App (für DocuSign Return-URL und Admin-Links). Bei Vercel: https://dein-projekt.vercel.app
# NEXT_PUBLIC_APP_URL=http://localhost:3002
# Optional: Basis-URL für den Link in der Zugangs-E-Mail. Wenn gesetzt, wird dieser Link in E-Mails verwendet (auch wenn Freigabe von localhost aus erfolgt). Auf Vercel = gleiche URL wie NEXT_PUBLIC_APP_URL; lokal setzen, wenn du von localhost freigibst, aber Vercel-Link in der E-Mail willst.
# ACCESS_LINK_BASE_URL=https://e-id-connect-lr65.vercel.app

# Admin-Direktzugang zur Demo (ohne NDA/DocuSign). Link: /api/admin/enter-demo?secret=DEIN_SECRET&demo_id=eid-demo-connect-v1
# ADMIN_DEMO_SECRET=dein-langes-geheimes-token
